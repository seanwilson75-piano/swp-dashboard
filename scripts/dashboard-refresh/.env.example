# Copy this file to `.env` in this same folder and fill in real values.
# `.env` is gitignored — it never gets committed. Node's built-in
# `--env-file` flag reads it directly; no extra dependency needed.
#
# These are LOCAL-ONLY credentials for running the script by hand (e.g. with
# Claude Code) or testing changes. The live GitHub Actions schedule does NOT
# read this file — it uses its own copies of the same three values stored as
# encrypted repo secrets (Settings → Secrets and variables → Actions).

FATHOM_API_TOKEN=
SURECART_API_KEY=
AIRTABLE_API_KEY=
